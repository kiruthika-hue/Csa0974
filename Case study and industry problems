import java.util.*;
class Production{
    int pid, target, produced;
    String pname;
    void read(){
        Scanner sc = new Scanner(System.in);
        pid = sc.nextInt(); sc.nextLine();
        pname = sc.nextLine();
        target = sc.nextInt();
        produced = sc.nextInt();
    }
    double efficiency(){
        return (double)produced / target * 100;
    }
    void display(){
        System.out.println(pid + " " + pname + " " + efficiency() + "%");
    }
    public static void main(String[] args){
        Production p = new Production();
        p.read();
        p.display();
    }
}
import java.util.*;
class Enrollment{
    int sid;
    String sname, course;
    double fee;
    void read(){
        Scanner sc = new Scanner(System.in);
        sid = sc.nextInt(); sc.nextLine();
        sname = sc.nextLine();
        course = sc.nextLine();
        fee = sc.nextDouble();
    }
    double payable(){
        return fee > 20000 ? fee - fee*0.15 : fee;
    }
    void display(){
        System.out.println(sid + " " + sname + " " + payable());
    }
    public static void main(String[] args){
        Enrollment e = new Enrollment();
        e.read();
        e.display();
    }
}
